{
  "manifest_version": 3,
  "name": "FastRevise",
  "version": "1.5",
  "description": "Quality of life improvements for efficiency in SmartRevise quiz.",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["*://smartrevise.online/*"],
      "js": ["index.js"],
      "css": ["style.css"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.smartrevise.online/*"],
      "js": ["settings.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
